%define refill_2afc_block ()
    bq_0 = 0
    bq_1 = 1
    bq_2 = 2
    bq_3 = 3
    bq_4 = 4
    bq_5 = 5

    bq_j = disc_rand(0, 5)
    bq_swap = bq_0
    if (bq_j == 1) {
        bq_0 = bq_1
        bq_1 = bq_swap
    }
    if (bq_j == 2) {
        bq_0 = bq_2
        bq_2 = bq_swap
    }
    if (bq_j == 3) {
        bq_0 = bq_3
        bq_3 = bq_swap
    }
    if (bq_j == 4) {
        bq_0 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j == 5) {
        bq_0 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(1, 5)
    bq_swap = bq_1
    if (bq_j == 2) {
        bq_1 = bq_2
        bq_2 = bq_swap
    }
    if (bq_j == 3) {
        bq_1 = bq_3
        bq_3 = bq_swap
    }
    if (bq_j == 4) {
        bq_1 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j == 5) {
        bq_1 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(2, 5)
    bq_swap = bq_2
    if (bq_j == 3) {
        bq_2 = bq_3
        bq_3 = bq_swap
    }
    if (bq_j == 4) {
        bq_2 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j == 5) {
        bq_2 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(3, 5)
    bq_swap = bq_3
    if (bq_j == 4) {
        bq_3 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j == 5) {
        bq_3 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(4, 5)
    bq_swap = bq_4
    if (bq_j == 5) {
        bq_4 = bq_5
        bq_5 = bq_swap
    }

    block_pos = 0
    report('2AFC block refilled')
%end

