///////////////////////////////////////////////////////////////////////////////
// Trial Samplers
///////////////////////////////////////////////////////////////////////////////

// 2AFC: 6-trial counterbalanced block
// Combo index encoding:  combo = stim_id * 3 + (face_index - 1)
//   stim_id    = combo / 3        (0 or 1)
//   face_index = combo % 3 + 1    (1, 2, or 3)
%define refill_2afc_block ()
    // Fill slots 0-5 with values 0-5
    bq_0 = 0
    bq_1 = 1
    bq_2 = 2
    bq_3 = 3
    bq_4 = 4
    bq_5 = 5

    // Fisher-Yates shuffle (6 elements)
    bq_j = disc_rand(0, 5)
    bq_swap = bq_0
if (bq_j == 1) {
        bq_0 = bq_1
        bq_1 = bq_swap
    }
if (bq_j == 2) {
        bq_0 = bq_2
        bq_2 = bq_swap
    }
if (bq_j == 3) {
        bq_0 = bq_3
        bq_3 = bq_swap
    }
if (bq_j == 4) {
        bq_0 = bq_4
        bq_4 = bq_swap
    }
if (bq_j == 5) {
        bq_0 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(1, 5)
    bq_swap = bq_1
if (bq_j == 2) {
        bq_1 = bq_2
        bq_2 = bq_swap
    }
if (bq_j == 3) {
        bq_1 = bq_3
        bq_3 = bq_swap
    }
if (bq_j == 4) {
        bq_1 = bq_4
        bq_4 = bq_swap
    }
if (bq_j == 5) {
        bq_1 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(2, 5)
    bq_swap = bq_2
if (bq_j == 3) {
        bq_2 = bq_3
        bq_3 = bq_swap
    }
if (bq_j == 4) {
        bq_2 = bq_4
        bq_4 = bq_swap
    }
if (bq_j == 5) {
        bq_2 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(3, 5)
    bq_swap = bq_3
if (bq_j == 4) {
        bq_3 = bq_4
        bq_4 = bq_swap
    }
if (bq_j == 5) {
        bq_3 = bq_5
        bq_5 = bq_swap
    }

    bq_j = disc_rand(4, 5)
    bq_swap = bq_4
if (bq_j == 5) {
        bq_4 = bq_5
        bq_5 = bq_swap
    }

    block_pos = 0
%end

%define decode_2afc_combo (combo)
    // combo 0-2: stim_id=0, face_index=1,2,3
    // combo 3-5: stim_id=1, face_index=1,2,3
    blank_id = 0
    if (combo == 0) {
        stim_id = 0
        face_index = 1
    }
    if (combo == 1) {
        stim_id = 0
        face_index = 2
    }
    if (combo == 2) {
        stim_id = 0
        face_index = 3
    }
    if (combo == 3) {
        stim_id = 1
        face_index = 1
    }
    if (combo == 4) {
        stim_id = 1
        face_index = 2
    }
    if (combo == 5) {
        stim_id = 1
        face_index = 3
    }
%end

%define sample_2afc_trial ()
    fixTimeDur = -fixTimeDurMean * logn(rand(0,1)) + fixTimeDurMin

    // Refill block if exhausted or first trial
    if (block_pos >= 6) {
        refill_2afc_block()
    }

    // Read current slot
    if (block_pos == 0) {
        decode_2afc_combo(bq_0)
    }
    if (block_pos == 1) {
        decode_2afc_combo(bq_1)
    }
    if (block_pos == 2) {
        decode_2afc_combo(bq_2)
    }
    if (block_pos == 3) {
        decode_2afc_combo(bq_3)
    }
    if (block_pos == 4) {
        decode_2afc_combo(bq_4)
    }
    if (block_pos == 5) {
        decode_2afc_combo(bq_5)
    }
    block_pos = block_pos + 1

    targetX  = (1 - 2 * stim_id) * target_eccentricity
    targetY  = 0
    targetSX = -targetX
    targetSY = 0

    // Apply current contrast to stimuli
    face_alpha      = current_contrast
    scrambled_alpha = current_contrast
%end

// YN: 12-trial counterbalanced block
// Combo index encoding:  combo = stim_id * 6 + blank_id * 3 + (face_index - 1)
//   stim_id    = combo / 6          (0 or 1)
//   blank_id   = (combo % 6) / 3    (0 or 1)
//   face_index = combo % 3 + 1      (1, 2, or 3)
%define refill_yn_block ()
    // Fill slots 0-11 with values 0-11
    bq_0  = 0
    bq_1  = 1
    bq_2  = 2
    bq_3  = 3
    bq_4  = 4
    bq_5  = 5
    bq_6  = 6
    bq_7  = 7
    bq_8  = 8
    bq_9  = 9
    bq_10 = 10
