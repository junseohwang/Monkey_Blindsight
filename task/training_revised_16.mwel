        bq_10 = bq_swap
    }
if (bq_j == 11) {
        bq_3 = bq_11
        bq_11 = bq_swap
    }

    bq_j = disc_rand(4,11)
    bq_swap = bq_4
    if (bq_j ==  5) {
        bq_4 = bq_5
        bq_5 = bq_swap
    }
    if (bq_j ==  6) {
        bq_4 = bq_6
        bq_6 = bq_swap
    }
    if (bq_j ==  7) {
        bq_4 = bq_7
        bq_7 = bq_swap
    }
    if (bq_j ==  8) {
        bq_4 = bq_8
        bq_8 = bq_swap
    }
    if (bq_j ==  9) {
