    }

    bq_j = disc_rand(2,11)
    bq_swap = bq_2
    if (bq_j ==  3) {
        bq_2 = bq_3
        bq_3 = bq_swap
    }
    if (bq_j ==  4) {
        bq_2 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j ==  5) {
        bq_2 = bq_5
        bq_5 = bq_swap
    }
    if (bq_j ==  6) {
        bq_2 = bq_6
        bq_6 = bq_swap
    }
    if (bq_j ==  7) {
        bq_2 = bq_7
        bq_7 = bq_swap
    }
    if (bq_j ==  8) {
        bq_2 = bq_8
        bq_8 = bq_swap
    }
    if (bq_j ==  9) {
        bq_2 = bq_9
        bq_9 = bq_swap
    }
if (bq_j == 10) {
        bq_2 = bq_10
        bq_10 = bq_swap
    }
if (bq_j == 11) {
        bq_2 = bq_11
        bq_11 = bq_swap
    }

    bq_j = disc_rand(3,11)
    bq_swap = bq_3
    if (bq_j ==  4) {
        bq_3 = bq_4
        bq_4 = bq_swap
    }
    if (bq_j ==  5) {
        bq_3 = bq_5
        bq_5 = bq_swap
    }
    if (bq_j ==  6) {
        bq_3 = bq_6
        bq_6 = bq_swap
    }
    if (bq_j ==  7) {
        bq_3 = bq_7
        bq_7 = bq_swap
    }
    if (bq_j ==  8) {
