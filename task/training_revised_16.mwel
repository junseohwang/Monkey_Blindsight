        bq_6 = bq_swap
    }
    if (bq_j ==  7) {
        bq_1 = bq_7
        bq_7 = bq_swap
    }
    if (bq_j ==  8) {
        bq_1 = bq_8
        bq_8 = bq_swap
    }
    if (bq_j ==  9) {
