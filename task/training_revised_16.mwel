    }
if (bq_j == 10) {
        bq_0 = bq_10
        bq_10 = bq_swap
    }
if (bq_j == 11) {
        bq_0 = bq_11
        bq_11 = bq_swap
    }

    bq_j = disc_rand(1,11)
    bq_swap = bq_1
    if (bq_j ==  2) {
        bq_1 = bq_2
        bq_2 = bq_swap
    }
    if (bq_j ==  3) {
        bq_1 = bq_3
        bq_3 = bq_swap
    }
    if (bq_j ==  4) {
        bq_1 = bq_4
        bq_4 = bq_swap
    }
