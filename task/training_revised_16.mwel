%define decode_yn_combo (combo)
    // combo 0-5:  stim_id=0, blank_id=0,0,0,1,1,1, face_index=1,2,3,1,2,3
    // combo 6-11: stim_id=1, blank_id=0,0,0,1,1,1, face_index=1,2,3,1,2,3
    if (combo ==  0) {
        stim_id = 0
        blank_id = 0
        face_index = 1
    }
    if (combo ==  1) {
        stim_id = 0
        blank_id = 0
        face_index = 2
    }
    if (combo ==  2) {
        stim_id = 0
        blank_id = 0
        face_index = 3
    }
    if (combo ==  3) {
        stim_id = 0
        blank_id = 1
        face_index = 1
    }
    if (combo ==  4) {
        stim_id = 0
        blank_id = 1
        face_index = 2
    }
    if (combo ==  5) {
        stim_id = 0
        blank_id = 1
        face_index = 3
    }
    if (combo ==  6) {
        stim_id = 1
        blank_id = 0
        face_index = 1
    }
    if (combo ==  7) {
        stim_id = 1
        blank_id = 0
        face_index = 2
    }
    if (combo ==  8) {
        stim_id = 1
        blank_id = 0
        face_index = 3
    }
    if (combo ==  9) {
        stim_id = 1
        blank_id = 1
        face_index = 1
    }
    if (combo == 10) {
        stim_id = 1
        blank_id = 1
        face_index = 2
    }
    if (combo == 11) {
        stim_id = 1
        blank_id = 1
        face_index = 3
    }
%end

%define sample_yn_trial ()
    fixTimeDur = -fixTimeDurMean * logn(rand(0,1)) + fixTimeDurMin

    // Refill block if exhausted
    if (block_pos >= 12) {
        refill_yn_block()
    }

    // Read current slot
    if (block_pos ==  0) {
        decode_yn_combo(bq_0)
    }
    if (block_pos ==  1) {
        decode_yn_combo(bq_1)
    }
    if (block_pos ==  2) {
        decode_yn_combo(bq_2)
    }
    if (block_pos ==  3) {
        decode_yn_combo(bq_3)
    }
    if (block_pos ==  4) {
        decode_yn_combo(bq_4)
    }
    if (block_pos ==  5) {
        decode_yn_combo(bq_5)
    }
    if (block_pos ==  6) {
        decode_yn_combo(bq_6)
    }
    if (block_pos ==  7) {
        decode_yn_combo(bq_7)
    }
    if (block_pos ==  8) {
        decode_yn_combo(bq_8)
    }
    if (block_pos ==  9) {
        decode_yn_combo(bq_9)
    }
    if (block_pos == 10) {
        decode_yn_combo(bq_10)
    }
    if (block_pos == 11) {
        decode_yn_combo(bq_11)
    }
    block_pos = block_pos + 1

    if (stim_id == 1) {
        targetX  = -target_eccentricity
        targetSX =  target_eccentricity
    }
    if (stim_id == 0) {
        targetX  =  target_eccentricity
        targetSX = -target_eccentricity
    }
    targetY  = 0
    targetSY = 0

    // Stage 4: blank_alpha controls fading side, other side at full contrast
    // Stage 5+: blank_alpha=0, visible side uses current_contrast
    face_alpha      = current_contrast
    scrambled_alpha = current_contrast

    if (blank_id == stim_id) {
        face_alpha = blank_alpha
    }
    if (blank_id != stim_id) {
        scrambled_alpha = blank_alpha
    }
%end

///////////////////////////////////////////////////////////////////////////////
// Staircase: blank_alpha  (Stage 4 — fade side from 1 to 0)
//   3-down-1-up on blank_alpha
//   correct 3x → alpha decreases (harder, blanker)
//   wrong   1x → alpha increases (easier, more visible)
///////////////////////////////////////////////////////////////////////////////

%define update_blank_alpha_success ()
    // Stage 4: every correct → blank_alpha *= 0.8 (harder, blanker)
    // Log scale: step proportional to current value
    if (training_stage == 4) {
        blank_alpha = blank_alpha * blank_alpha_step_factor
        if (blank_alpha < 0.01) {
            blank_alpha = 0.01
        }
        report('BLANK STAIRCASE DOWN (harder): blank_alpha = $blank_alpha')
    }
%end

%define update_blank_alpha_failure ()
    // Stage 4: every error → blank_alpha /= 0.8 (easier, more visible)
    // Log scale: step proportional to current value
    if (training_stage == 4) {
        blank_alpha = blank_alpha / blank_alpha_step_factor
        if (blank_alpha > 1.0) {
            blank_alpha = 1.0
        }
        report('BLANK STAIRCASE UP (easier): blank_alpha = $blank_alpha')
    }
%end

///////////////////////////////////////////////////////////////////////////////
// Staircase: current_contrast  (Stage 7 — calibration, 3-down-1-up)
///////////////////////////////////////////////////////////////////////////////

%define update_contrast_success ()
    // Stage 7: 3-down-1-up, log scale with step shrinking at reversals
    // 3 correct → multiply contrast by step_factor (harder)
    // At reversal (was going up, now going down) → step_factor moves toward 1.0 (smaller step)
    if (training_stage == 7 && task_mode == 1) {
        consecutive_corrects = consecutive_corrects + 1
        if (consecutive_corrects >= 3) {
            if (previous_direction == 1) {
                // reversal: shrink step toward 1.0 by contrast_step_shrink
                contrast_step_factor = 1.0 - (1.0 - contrast_step_factor) * contrast_step_shrink
                if (contrast_step_factor > contrast_step_factor_min) {
                    contrast_step_factor = contrast_step_factor_min
                }
            }
            current_contrast = current_contrast * contrast_step_factor
            if (current_contrast < 0.01) {
                current_contrast = 0.01
            }
            previous_direction   = -1
            consecutive_corrects = 0
            report('CONTRAST DOWN: contrast=$current_contrast step_factor=$contrast_step_factor')
        }
    }
%end

%define update_contrast_failure ()
    // Stage 7: 1 error → divide by step_factor (easier)
    // At reversal (was going down, now going up) → step_factor moves toward 1.0 (smaller step)
    if (training_stage == 7 && task_mode == 1) {
        if (previous_direction == -1) {
            // reversal: shrink step toward 1.0 by contrast_step_shrink
            contrast_step_factor = 1.0 - (1.0 - contrast_step_factor) * contrast_step_shrink
            if (contrast_step_factor > contrast_step_factor_min) {
                contrast_step_factor = contrast_step_factor_min
            }
        }
        current_contrast = current_contrast / contrast_step_factor
        if (current_contrast > 1.0) {
            current_contrast = 1.0
        }
        previous_direction   = 1
        consecutive_corrects = 0
        report('CONTRAST UP: contrast=$current_contrast step_factor=$contrast_step_factor')
    }
%end

///////////////////////////////////////////////////////////////////////////////
// Performance reporting
///////////////////////////////////////////////////////////////////////////////

%define update_performance_metrics (outcome)
    session_valid_trials = session_valid_trials + 1

    if (outcome == 1) {
        session_correct_count = session_correct_count + 1
    }

    // Track left choices for bias monitoring
    if (outcome == 1) {
        if (stim_id == 1) {
            session_left_choices = session_left_choices + 1
        }
    }
    if (outcome == 0) {
        if (stim_id == 0) {
            session_left_choices = session_left_choices + 1
        }
    }

    if (session_valid_trials > 0) {
        session_accuracy = round((session_correct_count / session_valid_trials) * 1000) / 10.0
        session_bias     = round((session_left_choices  / session_valid_trials) * 1000) / 10.0
    }

    // Stage 0-1: just count rewards, no task report
    if (training_stage <= 1) {
        report('Stage $training_stage | Rewards: $session_correct_count')
    }

    // Stage 2: stimulus toleration, no choice
    if (training_stage == 2) {
        report('Stage 2 (tolerate) | Trials: $session_valid_trials')
    }

    // Stage 3+: full task reporting
    if (training_stage >= 3) {
        if (task_mode == 1) {
            report('2AFC | Acc: $session_accuracy % | Bias: $session_bias % | Trials: $session_valid_trials | Contrast: $current_contrast')
        }
        if (task_mode == 0) {
            report('YN   | Acc: $session_accuracy % | Bias: $session_bias % | Trials: $session_valid_trials | blank_alpha: $blank_alpha')
        }
    }
%end

///////////////////////////////////////////////////////////////////////////////
// Protocol
///////////////////////////////////////////////////////////////////////////////

protocol 'Training' {
    start_device_io (eye_tracker)

    %ifdef monkey_ephys
        start_io_device (labjack)
    %end

    update_stimulus_display ()

    task Trials {

        // ── Initial ──────────────────────────────────────────────────────────
        state 'Initial' {
            // ── Trial counters ───────────────────────────────────────────
            localTrials           = 0
            CorrectTrials         = 0
            IncorrectTrials       = 0
            correction_needed     = 0

            // ── Session stats ────────────────────────────────────────────
            session_valid_trials  = 0
            session_correct_count = 0
            session_left_choices  = 0
            session_accuracy      = 0.0
            session_bias          = 0.0

            // ── Task mode + block ─────────────────────────────────────────
            task_mode         = 1       // start in 2AFC
            block_start_time  = now()
            block_pos         = 99      // force refill on first trial

            // ── Staircase state ───────────────────────────────────────────
            consecutive_corrects  = 0
            previous_direction    = 0
            contrast_step_factor  = contrast_step_factor_init  // reset to initial step size

            // ── Blank alpha ───────────────────────────────────────────────
            blank_alpha = 1.0
            if (training_stage >= 5) {
                blank_alpha = 0.0       // Stage 5+: blank side fully gone
            }

            // ── Stimulus alphas ───────────────────────────────────────────
            face_alpha      = 1.0
            scrambled_alpha = 1.0

            goto ('ITI')
        }

        // ── ITI ──────────────────────────────────────────────────────────────
        state 'ITI' {

            // Block switching: Stages 6 and 7 only
            if (training_stage >= 6) {
                if ((now() - block_start_time) / 1e6 >= block_duration) {
                    task_mode        = 1 - task_mode
                    block_start_time = now()
                    block_pos        = 99
                    if (task_mode == 1) {
                        report('BLOCK SWITCH: Now 2AFC')
                    }
                    if (task_mode == 0) {
                        report('BLOCK SWITCH: Now YN')
                    }
                }
            }

            // Force task mode for stages that use only one task
            if (training_stage <= 2) {
                task_mode = 1
            }
            if (training_stage == 3) {
                task_mode = 1
            }
            if (training_stage == 4) {
                task_mode = 0
            }
            if (training_stage == 5) {
                task_mode = 0
            }

            // Sample trial (skip if correction trial is pending)
            if (correction_needed == 0 || correction_enabled == 0) {
                if (task_mode == 1) {
                    sample_2afc_trial()
                }
                if (task_mode == 0) {
                    sample_yn_trial()
                    // Scrambled-visible bias for Stage 5 (Gaori avoidance training)
                    if (scrambled_bias_mode == 1 && training_stage == 5) {
                        if (rand(0,1) < scrambled_bias_prob) {
                            blank_id = stim_id
                        }
                        if (rand(0,1) >= scrambled_bias_prob) {
                            blank_id = stim_id + 1
                            if (blank_id > 1) {
                                blank_id = 0
                            }
                        }
                    }
                }
            }
            if (correction_needed == 1 && correction_enabled == 1) {
                report('CORRECTION TRIAL: stim_id=$stim_id  blank_id=$blank_id')
            }

            // Always update physical alphas to staircase values, even on correction trials
            if (task_mode == 1) {
                face_alpha      = current_contrast
                scrambled_alpha = current_contrast
            }
            if (task_mode == 0) {
                face_alpha      = current_contrast
                scrambled_alpha = current_contrast
                if (blank_id == stim_id) {
                    face_alpha = blank_alpha
                }
                if (blank_id != stim_id) {
                    scrambled_alpha = blank_alpha
                }
            }

            wait(ITI * 1000)
            goto ('Fix On')
        }

        // ── Fix On ───────────────────────────────────────────────────────────
        state 'Fix On' {
            live_queue_stimulus(fixCircleStatic)
            update_stimulus_display()

            tStart    = now()
            startTrial= 1
            id_bad    = 0
            report('Fix on')

            start_timer (
                timer          = fixWait
                duration       = fixWaitDur
                duration_units = ms
            )

            // Stage 0: reward immediately on fixation
            goto (
                target = 'Reward'
                when   = (on_fix_static && training_stage == 0)
            )
            // Stage 1+: require fixation hold
            goto (
                target = 'Static Fix'
                when   = (on_fix_static && training_stage >= 1)
            )
            timer_expired (
                target = 'Failure to fixate'
                timer  = fixWait
            )
        }

        // ── Static Fix ───────────────────────────────────────────────────────
        state 'Static Fix' {
            localTrials = localTrials + 1
            tFix        = now()
            id_bad      = 1

            start_timer (
                timer          = StaticFixWait
                duration       = fixTimeDur
                duration_units = ms
            )
            goto (
                target = 'Bad'
                when   = !on_fix_static
            )
            timer_expired (
                target = 'After Hold Router'
                timer  = StaticFixWait
            )
        }

        // ── After Hold Router ────────────────────────────────────────────────
        state 'After Hold Router' {
            // Stage 1: reward after hold, no stimulus needed
            goto (
                target = 'Reward'
                when   = (training_stage == 1)
            )
            // Stage 2+: show stimulus
            goto (
                target = 'Target On'
                when   = (training_stage >= 2)
            )
        }

        // ── Target On ────────────────────────────────────────────────────────
        state 'Target On' {
            %ifdef monkey_ephys
                queue_stimulus(photodiode)
            %end

            // ── 2AFC (task_mode=1): both stimuli at current_contrast ──
            if (task_mode == 1) {
                if (face_index == 1) {
                    queue_stimulus(monkey_face_1)
                }
                if (face_index == 2) {
                    queue_stimulus(monkey_face_2)
                }
                if (face_index == 3) {
                    queue_stimulus(monkey_face_3)
                }
                if (face_index == 1) {
                    queue_stimulus(monkey_scrambled_1)
                }
                if (face_index == 2) {
                    queue_stimulus(monkey_scrambled_2)
                }
                if (face_index == 3) {
                    queue_stimulus(monkey_scrambled_3)
                }
            }

            // ── YN (task_mode=0): alpha already set in sample_yn_trial() ──
            // face_alpha and scrambled_alpha are 1.0 or blank_alpha per side
            // Stage 5+: blank_alpha=0 so faded stimulus is invisible — skip queuing entirely
            if (task_mode == 0) {
                if (face_alpha > 0.0) {
                    if (face_index == 1) {
                        queue_stimulus(monkey_face_1)
                    }
                    if (face_index == 2) {
                        queue_stimulus(monkey_face_2)
                    }
                    if (face_index == 3) {
                        queue_stimulus(monkey_face_3)
                    }
                }
                if (scrambled_alpha > 0.0) {
                    if (face_index == 1) {
                        queue_stimulus(monkey_scrambled_1)
                    }
                    if (face_index == 2) {
                        queue_stimulus(monkey_scrambled_2)
                    }
                    if (face_index == 3) {
                        queue_stimulus(monkey_scrambled_3)
                    }
                }
            }

            play_sound (stimulus_cue)
            update_stimulus_display()
            id_bad = 2

            start_timer (
                timer          = timer_target_on
                duration       = targetTimeDur
                duration_units = ms
            )
            goto (
                target = 'Bad'
                when   = !on_fix_static
            )
            timer_expired (
                target = 'Noise Mask'
                timer  = timer_target_on
            )
        }

        // ── Noise Mask ───────────────────────────────────────────────────────
        state 'Noise Mask' {
            id_bad = 3

            dequeue_stimulus(monkey_face_1)
            dequeue_stimulus(monkey_face_2)
            dequeue_stimulus(monkey_face_3)
            dequeue_stimulus(monkey_scrambled_1)
            dequeue_stimulus(monkey_scrambled_2)
            dequeue_stimulus(monkey_scrambled_3)

            mask_index = disc_rand(1, 50)
            queue_stimulus(noise_mask_face)
            queue_stimulus(noise_mask_scrambled)
            live_queue_stimulus(fixCircleStatic)

            update_stimulus_display()

            start_timer (
                timer          = timer_mask_on
                duration       = maskTimeDur
                duration_units = ms
            )
            goto (
                target = 'Bad'
                when   = !on_fix_static
            )
            timer_expired (
                target = 'Post Mask Router'
                timer  = timer_mask_on
            )
        }

        // ── Post Mask Router ─────────────────────────────────────────────────
        state 'Post Mask Router' {
            // Stage 2: auto reward (toleration training — no response needed)
            goto (
                target = 'Reward'
                when   = (training_stage == 2)
            )
            // Stage 3+: require response
            goto (
                target = 'Fix Off'
                when   = (training_stage >= 3)
            )
        }

        // ── Fix Off ──────────────────────────────────────────────────────────
        state 'Fix Off' {
            id_bad = 5

            dequeue_stimulus(noise_mask_face)
            dequeue_stimulus(noise_mask_scrambled)
            dequeue_stimulus(fixCircleStatic)
            update_stimulus_display()

            tFixOff        = now()
            labjack_fix_off= 1

            live_queue_stimulus(target_window)
            live_queue_stimulus(nontarget_window)
            live_queue_stimulus(correctDot)
            live_queue_stimulus(wrongDot)
            update_stimulus_display()

            goto ('Response')
        }

        // ── Response ─────────────────────────────────────────────────────────
        state 'Response' {
            id_bad = 6

            start_timer (
                timer          = timer_response
                duration       = targetWait
                duration_units = ms
            )
            goto (
                target = 'post_response'
                when   = on_target
            )
            goto (
                target = 'Bad'
                when   = on_nontarget
            )
            timer_expired (
                target = 'Timeout_Router'
                timer  = timer_response
            )
        }

        // ── Timeout Router ───────────────────────────────────────────────────
        state 'Timeout_Router' {
            id_bad = 9
            goto ('Bad')
        }

        // ── Post Response ────────────────────────────────────────────────────
        state 'post_response' {
            id_bad    = 7
            tResponse = now()

            start_timer (
                timer          = timer_post_response
                duration       = responseRegister
                duration_units = ms
            )
            goto (
                target = 'Response'
                when   = !on_target
            )
            timer_expired (
                target = 'Reward'
                timer  = timer_post_response
            )
        }

        // ── Reward ───────────────────────────────────────────────────────────
        state 'Reward' {
            correction_needed = 0

            fix_red_static  = 0
            fix_blue_static = 0
            labjack_target_on = 0

            dequeue_stimulus(wrongDot)
            dequeue_stimulus(correctDot)
            dequeue_stimulus(target_window)
            dequeue_stimulus(nontarget_window)
            dequeue_stimulus(noise_mask_face)
            dequeue_stimulus(noise_mask_scrambled)
            dequeue_stimulus(monkey_face_1)
            dequeue_stimulus(monkey_face_2)
            dequeue_stimulus(monkey_face_3)
            dequeue_stimulus(monkey_scrambled_1)
            dequeue_stimulus(monkey_scrambled_2)
            dequeue_stimulus(monkey_scrambled_3)

            // Visual feedback on correct response (Stages 3+)
            if (training_stage >= 3) {
                face_alpha = 1.0
                if (face_index == 1) {
                    queue_stimulus(monkey_face_1)
                }
                if (face_index == 2) {
                    queue_stimulus(monkey_face_2)
                }
                if (face_index == 3) {
                    queue_stimulus(monkey_face_3)
                }
                update_stimulus_display()
            }

            update_performance_metrics(1)
            update_blank_alpha_success()
            update_contrast_success()

            action/play_sound(success_sound)
            tRew = now()

            %ifdef monkey_ephys
                queue_stimulus(photodiode)
                update_stimulus_display()
            %end

            CorrectTrials = CorrectTrials + 1

            pulse (
                variable       = reward_line
                duration       = rewardDur * 1000
            )
            start_timer (
                timer          = GreenTime
                duration       = rewardDur
                duration_units = ms
            )
            timer_expired (
                target = 'End Trial'
                timer  = GreenTime
            )
        }

        // ── Failure to Fixate ────────────────────────────────────────────────
        state 'Failure to fixate' {
            tResponse = now()
            start_timer (
                timer          = NoFixWait
                duration       = NoFixWaitDur
                duration_units = ms
            )
            timer_expired (
                target = 'End Trial'
                timer  = NoFixWait
            )
        }

        // ── Bad ──────────────────────────────────────────────────────────────
        state 'Bad' {
            tResponse = now()

            // 1. Choice error (id_bad 6 or 9) — applies Stage 3+
            if (id_bad == 6 || id_bad == 9) {
                if (correction_enabled == 1 && training_stage >= 3) {
                    correction_needed = 1
                    report('CORRECTION TRIAL SET: stim_id=$stim_id  blank_id=$blank_id')
                }
                update_performance_metrics(0)
                update_blank_alpha_failure()
                update_contrast_failure()
            }

            // 2. Fixation break (ids 1-4 only) 
            // --> FIX: We removed "correction_needed = 0" from here so 
            // fixation breaks do NOT wipe out a pending correction trial.

            // 3. Cleanup
            if (id_bad <= 4 || id_bad == 2 || id_bad == 3 || id_bad == 8) {
                dequeue_stimulus(monkey_face_1)
                dequeue_stimulus(monkey_face_2)
                dequeue_stimulus(monkey_face_3)
                dequeue_stimulus(monkey_scrambled_1)
                dequeue_stimulus(monkey_scrambled_2)
                dequeue_stimulus(monkey_scrambled_3)
                dequeue_stimulus(noise_mask_face)
                dequeue_stimulus(noise_mask_scrambled)
                dequeue_stimulus(target_window)
                dequeue_stimulus(nontarget_window)
                dequeue_stimulus(fixCircleStatic)
                update_stimulus_display()
                labjack_target_on = 0
                labjack_cue_on    = 0
            }

            // 4. Audio + visual feedback for choice/timeout errors
            if (id_bad == 5 || id_bad == 6 || id_bad == 9) {
                fix_green_static = 0
                fix_blue_static  = 0
                dequeue_stimulus(correctDot)
                dequeue_stimulus(wrongDot)
                update_stimulus_display()
                labjack_cue_on = 1
                action/play_sound(failure_sound)
            }

            // Visual feedback: show what the correct answer was (Stages 3+)
            if (training_stage >= 3) {
                if (id_bad == 6) {
                    // Wrong saccade — show correct stimulus at full contrast
                    face_alpha = 1.0
                    if (face_index == 1) {
                        queue_stimulus(monkey_face_1)
                    }
                    if (face_index == 2) {
                        queue_stimulus(monkey_face_2)
                    }
                    if (face_index == 3) {
                        queue_stimulus(monkey_face_3)
                    }
                    update_stimulus_display()
                    timeout = 1000
                }
                if (id_bad == 9) {
                    // Timeout — show both at full contrast
                    face_alpha = 1.0
                    scrambled_alpha = 1.0
                    if (face_index == 1) {
                        queue_stimulus(monkey_face_1)
                    }
                    if (face_index == 2) {
                        queue_stimulus(monkey_face_2)
                    }
                    if (face_index == 3) {
                        queue_stimulus(monkey_face_3)
                    }
                    if (face_index == 1) {
                        queue_stimulus(monkey_scrambled_1)
                    }
                    if (face_index == 2) {
                        queue_stimulus(monkey_scrambled_2)
                    }
                    if (face_index == 3) {
                        queue_stimulus(monkey_scrambled_3)
                    }
                    update_stimulus_display()
                    timeout = 1000
                }
            }

            start_timer (
                timer          = timer_timeout
                duration       = timeout
                duration_units = ms
            )
            timer_expired (
                target = 'End Trial'
                timer  = timer_timeout
            )
        }

        // ── End Trial ────────────────────────────────────────────────────────
        state 'End Trial' {
            tEnd = now()
            endTrial = endTrial + 1

            // Reset fixation color
            fix_red_static   = 1
            fix_green_static = 1
            fix_blue_static  = 1

            dot_alpha    = 1
            reward_count = 0
            elapsed_time = 0

            dequeue_stimulus(photodiode)
            dequeue_stimulus(target_window)
            dequeue_stimulus(nontarget_window)
            dequeue_stimulus(correctDot)
            dequeue_stimulus(wrongDot)
            dequeue_stimulus(monkey_face_1)
            dequeue_stimulus(monkey_face_2)
            dequeue_stimulus(monkey_face_3)
            dequeue_stimulus(monkey_scrambled_1)
            dequeue_stimulus(monkey_scrambled_2)
            dequeue_stimulus(monkey_scrambled_3)
            dequeue_stimulus(noise_mask_face)
            dequeue_stimulus(noise_mask_scrambled)
            dequeue_stimulus(fixCircleStatic)
            update_stimulus_display()

            id_bad        = 0
            flag_response = 0
            targetWait    = targetWait0

            labjack_target_on = 0
            labjack_fix_off   = 0
            labjack_cue_on    = 0

            goto (
                target = 'Exit System'
                when   = CorrectTrials >= trialNum
            )
            goto (
                target = 'Exit System'
                when   = pstop
            )
            goto ('ITI')
        }

        // ── Exit ─────────────────────────────────────────────────────────────
        state 'Exit System' {
            report('Session complete. CorrectTrials=$CorrectTrials')
            yield()
        }

    } // end task Trials
} // end protocol
